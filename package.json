{
  "name": "@vue/ecosystem-ci",
  "version": "0.0.1",
  "private": true,
  "description": "Vue Ecosystem CI",
  "homepage": "https://github.com/ubugeeei/ecosystem-ci-vue-vapor#readme",
  "bugs": {
    "url": "https://github.com/ubugeeei/ecosystem-ci-vue-vapor/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubugeeei/ecosystem-ci-vue-vapor.git"
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm install --dir typings",
    "prepare": "vp config",
    "check": "vp check",
    "check:testbeds": "node .github/scripts/check-testbed-licenses.ts",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt . --check",
    "format:fix": "vp fmt . --write",
    "typecheck": "vp check --no-fmt --no-lint",
    "test:self": "node ecosystem-ci.ts _selftest",
    "test": "node ecosystem-ci.ts",
    "clean": "node .github/scripts/clean-workspace.ts",
    "bisect": "node ecosystem-ci.ts bisect"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "cac": "^6.7.14",
    "execa": "^9.6.1",
    "verdaccio": "^6.7.1",
    "verdaccio-auth-memory": "^13.0.1"
  },
  "devDependencies": {
    "@antfu/ni": "^28.2.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.22",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": "^10.30.3"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "cookie@<0.7.0": "^1.1.1",
      "fast-uri@<=3.1.1": "^3.1.2",
      "handlebars@<=4.7.8": "^4.7.9",
      "jws@<3.2.3": "^3.2.3",
      "js-yaml@>=4.0.0 <4.1.1": "^4.1.1",
      "lodash@>=4.0.0 <=4.17.23": "^4.18.1",
      "path-to-regexp@<0.1.13": "^0.1.13",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "qs@<6.15.2": "^6.15.2",
      "undici@<6.24.0": "^6.24.0",
      "uuid@<11.1.1": "^11.1.1",
      "glob@>=11.0.0 <11.1.0": "^11.1.0",
      "validator@<13.15.22": "^13.15.26",
      "minimatch@>=7.0.0 <7.4.8": "^7.4.9",
      "ajv@8.17.1": "^8.18.0"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-v6h2-p8h4-qcjw",
        "GHSA-9965-vmph-33xx"
      ],
      "ignoreCves": [
        "CVE-2025-57319"
      ]
    }
  }
}
